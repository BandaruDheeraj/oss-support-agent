# --- Required ---
GITHUB_TOKEN=ghp_xxx                  # PAT with repo+workflow on the fork org
WEBHOOK_SECRET=change-me              # must match GitHub webhook secret
DEFAULT_FORK_ORG=your-bot-org         # owner of the bot fork

# --- Storage (Render: leave defaults from render.yaml) ---
# STATE_ROOT=/var/data/state
# WORKSPACE_ROOT=/var/data/workspaces
# REPO_ROOT=/opt/render/project/src   # auto-set by Render

# --- Mail (Resend) — required for PM design loop + auto-onboarding ---
RESEND_API_KEY=re_xxx                 # https://resend.com/api-keys
RESEND_FROM_ADDRESS=bot@yourdomain.com # MUST be a verified Resend sender
RESEND_REPLY_TO_BASE=bot@inbound.yourdomain.com  # base address for plus-tagged replies; defaults to RESEND_FROM_ADDRESS
RESEND_WEBHOOK_SECRET=whsec_xxx       # signing secret from the Resend webhook page

# --- LLM (optional; heuristic fallback when absent) ---
OPENROUTER_API_KEY=
# Optional comma-separated backup API keys used for automatic failover when
# the primary key is credits-exhausted / rate-limited / provider-unavailable.
OPENROUTER_API_KEYS=
# OPENROUTER_API_KEY_FALLBACKS=
# Optional per-stage model overrides. Falls back to OPENROUTER_MODEL or built-in default.
# Repro generation benefits from a strong reasoning model (it iteratively reads code
# and must produce a working bug-reproducing script). Recommended:
#   OPENROUTER_MODEL_REPRO=anthropic/claude-opus-4
# (or another top-tier reasoning model your account has access to)
# OPENROUTER_MODEL_REPRO=
# Optional comma-separated model fallback chain after the selected model.
OPENROUTER_MODEL_FALLBACKS=
# Optional per-agent model fallback chain (examples):
# OPENROUTER_MODEL_FALLBACKS_ANALYST=
# OPENROUTER_MODEL_FALLBACKS_REPRO_PROBER=

# --- Git author for fix commits ---
GIT_AUTHOR_NAME=oss-support-agent
GIT_AUTHOR_EMAIL=agent@users.noreply.github.com

# --- Server ---
PORT=3000

# --- Phase E v2 (loop-mode agents) ---
# OTEL dual-export (both backends optional; either disables when its envs are absent)
PHOENIX_OTLP_ENDPOINT=
PHOENIX_OTLP_HEADERS=                  # e.g. 'api-key=abc' (comma-separated k=v pairs)
PHOENIX_UI_BASE_URL=                   # used to build deep-trace links in emails
BRAINTRUST_OTLP_ENDPOINT=
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=
BRAINTRUST_ORG=

# HITL signing key (required for repro/fix loops in v2)
HITL_SIGNING_KEY=change-me-32-bytes-hex
HITL_REPLY_TO_BASE=osa-reply@yourdomain.com

# Eval recorder backend (stores per-run pipeline outcomes for outcome comparison)
OSA_EVAL_BACKEND=sqlite                # sqlite | jsonl | noop
OSA_EVAL_PATH=.osa-evals.sqlite

# HITL inbox store path
OSA_INBOX_DB_PATH=.osa-inbox.sqlite

# Redaction extras (comma-separated additional env-var names to scrub)
REDACT_DENY=

# --- Pluggable observability ---
# Set OBSERVABILITY_BACKEND to one of: langsmith | arize | braintrust | all | none
# Use "all" to fan out traces + online evaluator spans to all three platforms.
# In live server mode, "all" is fail-fast: startup exits if any required backend
# config is missing (LangSmith key, Arize/Phoenix endpoint, Braintrust key).
# Default ("none") loads no SDK and emits zero spans — true no-op.
OBSERVABILITY_BACKEND=none
# OBSERVABILITY_REDACT_IO=true replaces input/output payloads on each span
# with { redacted, length, sha1 } so latency/tokens stay observable but raw
# prompt/completion text never leaves the process. Default: false.
OBSERVABILITY_REDACT_IO=false

# LangSmith (used when OBSERVABILITY_BACKEND=langsmith or all)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=oss-support-agent
LANGSMITH_ENDPOINT=

# Arize / Phoenix (used when OBSERVABILITY_BACKEND=arize or all)
# ARIZE_ENDPOINT is the OTLP/HTTP traces URL (Arize Cloud or self-hosted
# Phoenix). If unset the adapter falls back to PHOENIX_OTLP_ENDPOINT above.
ARIZE_ENDPOINT=
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Braintrust (used when OBSERVABILITY_BACKEND=braintrust or all)
# Note: BRAINTRUST_API_KEY and BRAINTRUST_PROJECT above are reused; the
# pluggable adapter does NOT require BRAINTRUST_OTLP_ENDPOINT (it uses the
# braintrust SDK directly, not OTLP).
BRAINTRUST_API_URL=

# --- Comparison harness (evals/run-eval.ts) ---
# Outcome mode reads OSA_EVAL_PATH and compares repro/fix/verification/resolution
# rates across backend-specific runs. Run the same issue set with
# OBSERVABILITY_BACKEND=arize|braintrust|langsmith, then execute:
#   npm run eval:observability
# Legacy golden-set triage mode remains available:
#   npm run eval:observability:triage

# Direct Anthropic SDK (optional — if absent, the wrapper falls back to the
# existing OpenRouter LLMClient at core/llm/client.ts).
ANTHROPIC_API_KEY=

# Phoenix — local OR cloud. Local needs the endpoint; cloud needs the API key.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
ARIZE_SPACE_KEY=                       # cloud Arize / Phoenix Cloud space key

# LangSmith — adapter accepts either LANGCHAIN_API_KEY or LANGSMITH_API_KEY.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=oss-fix-loop

# Braintrust — enable the always-on Logger in addition to the Experiment.
BRAINTRUST_ENABLE_LOGGER=false
